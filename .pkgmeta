package-as: FluentWoW

enable-nolib-creation: no

ignore:
  - .help
  - .help/**
  - .docs
  - .docs/**
  - .vscode
  - .vscode/**
  - .github
  - .github/**
  - .luacheckrc
  - .gitattributes
  - .gitignore
  - FluentWoW-Gallery
  - wiki
  - wiki/**

externals:
  FluentWoW/Libs/LibStub: https://repos.curseforge.com/wow/libstub/trunk

move-folders:
  FluentWoW/FluentWoW: FluentWoW
