package-as: FluentWoW

enable-nolib-creation: no

ignore:
  - .help
  - .help/**
  - .docs
  - .docs/**
  - .vscode
  - .vscode/**
  - .github
  - .github/**
  - .luacheckrc
  - .gitattributes
  - .gitignore
  - ARCHITECTURE.md
  - FluentWoW-Gallery

externals:
  FluentWoW/Libs/LibStub: https://repos.curseforge.com/wow/libstub/trunk
  FluentWoW/Libs/Ace3: https://repos.curseforge.com/wow/ace3/trunk

move-folders:
  FluentWoW/FluentWoW: FluentWoW
