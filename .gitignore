# Ignore everything by default.
*

# Keep the repo policy and release metadata tracked.
!/.gitattributes
!/.gitignore
!/.luacheckrc
!/.pkgmeta
!/CHANGELOG.md
!/LICENSE
!/README.md

# Keep the addon payloads tracked.
!/FluentWoW/
!/FluentWoW/**
!/FluentWoW-Gallery/
!/FluentWoW-Gallery/**

# Keep wiki sources tracked, but release packaging excludes them.
!/wiki/
!/wiki/**

# Keep common editor and merge artifacts out of addon trees.
*.bak
.DS_Store
._*
*.orig
*.pkgmeta.bak
*.rej
*.swp
*.swo
*.tmp
*.temp
*~
*.luac
luac.out
.release/
Thumbs.db
Desktop.ini

# Keep only the addon-relevant workflow tracked.
!/.github/
.github/*
!/.github/workflows/
.github/workflows/*
!/.github/workflows/lint.yml
!/.github/workflows/wiki-sync.yml
