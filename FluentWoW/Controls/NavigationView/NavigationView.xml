<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <!-- ================================================================
         FWoWNavigationViewTemplate — Sidebar navigation control
         Size: 300×400  |  Parts: Pane, PaneBG, Divider, NavItems, ContentArea
         ================================================================ -->
    <Frame name="FWoWNavigationViewTemplate" virtual="true">
        <Size x="300" y="400"/>
        <Frames>
            <Frame name="$parent_Pane" parentKey="Pane">
                <Size x="48" y="0"/>
                <Anchors>
                    <Anchor point="TOPLEFT"/>
                    <Anchor point="BOTTOMLEFT"/>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture name="$parent_PaneBG" parentKey="PaneBG" setAllPoints="true"/>
                    </Layer>
                </Layers>
                <Frames>
                    <Button name="$parent_ToggleBtn" parentKey="ToggleBtn">
                        <Size x="40" y="40"/>
                        <Anchors>
                            <Anchor point="TOPLEFT" x="4" y="-4"/>
                        </Anchors>
                        <Layers>
                            <Layer level="BACKGROUND">
                                <Texture name="$parent_BG" parentKey="BG" setAllPoints="true" hidden="true"/>
                            </Layer>
                            <Layer level="ARTWORK">
                                <FontString name="$parent_Icon" parentKey="Icon"
                                    inherits="GameFontNormal" justifyH="CENTER">
                                    <Anchors>
                                        <Anchor point="CENTER"/>
                                    </Anchors>
                                </FontString>
                            </Layer>
                        </Layers>
                        <Scripts>
                            <OnClick function="FWoWNavToggleBtn_OnClick"/>
                            <OnEnter function="FWoWNavToggleBtn_OnEnter"/>
                            <OnLeave function="FWoWNavToggleBtn_OnLeave"/>
                        </Scripts>
                    </Button>
                    <Frame name="$parent_ItemContainer" parentKey="ItemContainer">
                        <Anchors>
                            <Anchor point="TOPLEFT" x="0" y="-44"/>
                            <Anchor point="BOTTOMRIGHT"/>
                        </Anchors>
                    </Frame>
                </Frames>
            </Frame>
            <Frame name="$parent_Divider" parentKey="Divider">
                <Size x="1" y="0"/>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="$parent_Pane" relativePoint="TOPRIGHT"/>
                    <Anchor point="BOTTOMLEFT" relativeTo="$parent_Pane" relativePoint="BOTTOMRIGHT"/>
                </Anchors>
                <Layers>
                    <Layer level="BORDER">
                        <Texture name="$parent_Line" parentKey="Line" setAllPoints="true"/>
                    </Layer>
                </Layers>
            </Frame>
            <Frame name="$parent_ContentArea" parentKey="ContentArea">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="$parent_Divider" relativePoint="TOPRIGHT"/>
                    <Anchor point="BOTTOMRIGHT"/>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture name="$parent_ContentBG" parentKey="ContentBG" setAllPoints="true"/>
                    </Layer>
                </Layers>
            </Frame>
        </Frames>
        <Scripts>
            <OnLoad function="FWoWNavigationView_OnLoad"/>
        </Scripts>
    </Frame>

    <!-- Nav item template (used by FramePool) -->
    <Button name="FWoWNavItemTemplate" virtual="true">
        <Size x="200" y="40"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parent_BG" parentKey="BG" setAllPoints="true" hidden="true"/>
            </Layer>
            <Layer level="BORDER">
                <Texture name="$parent_Indicator" parentKey="Indicator" hidden="true">
                    <Size x="3" y="16"/>
                    <Anchors>
                        <Anchor point="LEFT" x="0" y="0"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="$parent_Icon" parentKey="Icon"
                    inherits="GameFontNormal" justifyH="CENTER">
                    <Size x="20" y="20"/>
                    <Anchors>
                        <Anchor point="LEFT" x="12" y="0"/>
                    </Anchors>
                </FontString>
                <FontString name="$parent_Label" parentKey="Label"
                    inherits="GameFontNormal" justifyH="LEFT">
                    <Anchors>
                        <Anchor point="LEFT" relativeTo="$parent_Icon" relativePoint="RIGHT" x="12" y="0"/>
                        <Anchor point="RIGHT" x="-8" y="0"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Scripts>
            <OnClick function="FWoWNavItem_OnClick"/>
            <OnEnter function="FWoWNavItem_OnEnter"/>
            <OnLeave function="FWoWNavItem_OnLeave"/>
        </Scripts>
    </Button>

</Ui>
