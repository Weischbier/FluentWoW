<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <!-- ================================================================
         FWoWTeachingTipTemplate — Contextual teaching callout / coach mark
         Size: 320×auto  |  Parts: Card, TitleLabel, BodyLabel, CloseBtn,
               ActionBtn, Arrow
         ================================================================ -->
    <Frame name="FWoWTeachingTipTemplate" virtual="true" hidden="true"
        frameStrata="TOOLTIP" enableMouse="true" toplevel="true">
        <Size x="320" y="160"/>
        <Frames>
            <Frame name="$parent_Card" parentKey="Card">
                <Anchors>
                    <Anchor point="TOPLEFT"/>
                    <Anchor point="BOTTOMRIGHT"/>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture name="$parent_BG" parentKey="BG" setAllPoints="true"/>
                    </Layer>
                    <Layer level="BORDER">
                        <Texture name="$parent_Border" parentKey="Border" setAllPoints="true"/>
                    </Layer>
                    <Layer level="ARTWORK">
                        <FontString name="$parent_TitleLabel" parentKey="TitleLabel"
                            inherits="GameFontNormalLarge" justifyH="LEFT">
                            <Anchors>
                                <Anchor point="TOPLEFT" x="16" y="-16"/>
                                <Anchor point="RIGHT" x="-36" y="0"/>
                            </Anchors>
                        </FontString>
                        <FontString name="$parent_BodyLabel" parentKey="BodyLabel"
                            inherits="GameFontHighlight" justifyH="LEFT" justifyV="TOP">
                            <Anchors>
                                <Anchor point="TOPLEFT" relativeTo="$parent_TitleLabel"
                                    relativePoint="BOTTOMLEFT" x="0" y="-8"/>
                                <Anchor point="RIGHT" x="-16" y="0"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Frames>
                    <Button name="$parent_CloseBtn" parentKey="CloseBtn">
                        <Size x="20" y="20"/>
                        <Anchors>
                            <Anchor point="TOPRIGHT" x="-8" y="-8"/>
                        </Anchors>
                        <Layers>
                            <Layer level="ARTWORK">
                                <FontString name="$parent_X" parentKey="X"
                                    inherits="GameFontNormal" justifyH="CENTER" text="x">
                                    <Anchors>
                                        <Anchor point="CENTER"/>
                                    </Anchors>
                                </FontString>
                            </Layer>
                        </Layers>
                        <Scripts>
                            <OnClick function="FWoWTeachingTip_Close_OnClick"/>
                        </Scripts>
                    </Button>
                    <Frame name="$parent_ActionSlot" parentKey="ActionSlot">
                        <Size x="0" y="32"/>
                        <Anchors>
                            <Anchor point="BOTTOMLEFT" x="16" y="16"/>
                            <Anchor point="BOTTOMRIGHT" x="-16" y="16"/>
                        </Anchors>
                    </Frame>
                </Frames>
            </Frame>
            <Frame name="$parent_Arrow" parentKey="Arrow">
                <Size x="16" y="8"/>
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture name="$parent_Tex" parentKey="Tex" setAllPoints="true"/>
                    </Layer>
                </Layers>
            </Frame>
        </Frames>
        <Scripts>
            <OnLoad function="FWoWTeachingTip_OnLoad"/>
        </Scripts>
    </Frame>

</Ui>
