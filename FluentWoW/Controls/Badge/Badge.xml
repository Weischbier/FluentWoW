<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <!-- ================================================================
         FWoWBadgeTemplate — Status pill / badge indicator
         Size: auto×20  |  Parts: BG, Icon, Label
         ================================================================ -->
    <Frame name="FWoWBadgeTemplate" virtual="true">
        <Size x="48" y="20"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parent_BG" parentKey="BG" setAllPoints="true"/>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="$parent_Icon" parentKey="Icon"
                    inherits="GameFontNormalSmall" justifyH="CENTER" hidden="true">
                    <Size x="12" y="12"/>
                    <Anchors>
                        <Anchor point="LEFT" x="6" y="0"/>
                    </Anchors>
                </FontString>
                <FontString name="$parent_Label" parentKey="Label"
                    inherits="GameFontNormalSmall" justifyH="CENTER">
                    <Anchors>
                        <Anchor point="CENTER"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Scripts>
            <OnLoad function="FWoWBadge_OnLoad"/>
        </Scripts>
    </Frame>

</Ui>
