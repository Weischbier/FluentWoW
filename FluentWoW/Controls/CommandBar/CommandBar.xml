<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <!-- ================================================================
         FWoWCommandBarTemplate — Toolbar with primary + overflow commands
         Size: 400×40  |  Parts: BG, PrimaryContainer, OverflowBtn
         ================================================================ -->
    <Frame name="FWoWCommandBarTemplate" virtual="true">
        <Size x="400" y="40"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parent_BG" parentKey="BG" setAllPoints="true"/>
            </Layer>
            <Layer level="BORDER">
                <Texture name="$parent_TopEdge" parentKey="TopEdge">
                    <Size x="0" y="1"/>
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="TOPRIGHT"/>
                    </Anchors>
                </Texture>
                <Texture name="$parent_BottomEdge" parentKey="BottomEdge">
                    <Size x="0" y="1"/>
                    <Anchors>
                        <Anchor point="BOTTOMLEFT"/>
                        <Anchor point="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
        <Frames>
            <Frame name="$parent_PrimaryContainer" parentKey="PrimaryContainer">
                <Anchors>
                    <Anchor point="TOPLEFT" x="4" y="-4"/>
                    <Anchor point="BOTTOMLEFT" x="4" y="4"/>
                    <Anchor point="RIGHT" x="-40" y="0"/>
                </Anchors>
            </Frame>
            <Button name="$parent_OverflowBtn" parentKey="OverflowBtn" hidden="true">
                <Size x="32" y="32"/>
                <Anchors>
                    <Anchor point="RIGHT" x="-4" y="0"/>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture name="$parent_BG" parentKey="BG" setAllPoints="true" hidden="true"/>
                    </Layer>
                    <Layer level="ARTWORK">
                        <FontString name="$parent_Icon" parentKey="Icon"
                            inherits="GameFontNormal" justifyH="CENTER">
                            <Anchors>
                                <Anchor point="CENTER"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Scripts>
                    <OnClick function="FWoWCommandBar_Overflow_OnClick"/>
                    <OnEnter function="FWoWCommandBar_Overflow_OnEnter"/>
                    <OnLeave function="FWoWCommandBar_Overflow_OnLeave"/>
                </Scripts>
            </Button>
        </Frames>
        <Scripts>
            <OnLoad function="FWoWCommandBar_OnLoad"/>
        </Scripts>
    </Frame>

    <!-- Command bar item template (used by FramePool) -->
    <Button name="FWoWCommandBarItemTemplate" virtual="true">
        <Size x="32" y="32"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parent_BG" parentKey="BG" setAllPoints="true" hidden="true"/>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="$parent_Icon" parentKey="Icon"
                    inherits="GameFontNormal" justifyH="CENTER">
                    <Size x="16" y="16"/>
                    <Anchors>
                        <Anchor point="CENTER" x="0" y="2"/>
                    </Anchors>
                </FontString>
                <FontString name="$parent_Label" parentKey="Label"
                    inherits="GameFontNormalSmall" justifyH="CENTER" hidden="true">
                    <Anchors>
                        <Anchor point="TOP" relativeTo="$parent_Icon" relativePoint="BOTTOM" x="0" y="-2"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Scripts>
            <OnClick function="FWoWCommandBarItem_OnClick"/>
            <OnEnter function="FWoWCommandBarItem_OnEnter"/>
            <OnLeave function="FWoWCommandBarItem_OnLeave"/>
        </Scripts>
    </Button>

</Ui>
