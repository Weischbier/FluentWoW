<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <!-- ================================================================
         FWoWContentDialogTemplate — Modal dialog overlay
         Size: 480×auto  |  Parts: Overlay, Card, TitleLabel, BodyLabel,
               ButtonRow, PrimaryBtn, SecondaryBtn, CloseBtn
         Pixel-fidelity: DesignSpecs §2.2 (Dialog)
         ================================================================ -->
    <Frame name="FWoWContentDialogTemplate" virtual="true" hidden="true"
        frameStrata="DIALOG" enableMouse="true" toplevel="true">
        <Anchors>
            <Anchor point="TOPLEFT" relativeTo="UIParent"/>
            <Anchor point="BOTTOMRIGHT" relativeTo="UIParent"/>
        </Anchors>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parent_Overlay" parentKey="Overlay" setAllPoints="true"/>
            </Layer>
        </Layers>
        <Frames>
            <Frame name="$parent_Card" parentKey="Card">
                <Size x="480" y="260"/>
                <Anchors>
                    <Anchor point="CENTER"/>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture name="$parent_BG" parentKey="BG" setAllPoints="true"/>
                    </Layer>
                    <Layer level="ARTWORK">
                        <!-- Title: 32px from top -->
                        <FontString name="$parent_TitleLabel" parentKey="TitleLabel"
                            inherits="GameFontNormalLarge" justifyH="LEFT">
                            <Anchors>
                                <Anchor point="TOPLEFT" x="24" y="-32"/>
                                <Anchor point="RIGHT" x="-24" y="0"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                    <Layer level="ARTWORK">
                        <!-- Body: 24px below title -->
                        <FontString name="$parent_BodyLabel" parentKey="BodyLabel"
                            inherits="GameFontHighlight" justifyH="LEFT" justifyV="TOP">
                            <Anchors>
                                <Anchor point="TOPLEFT" relativeTo="$parent_TitleLabel"
                                    relativePoint="BOTTOMLEFT" x="0" y="-24"/>
                                <Anchor point="RIGHT" x="-24" y="0"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Frames>
                    <!-- Button row: 24px from bottom -->
                    <Frame name="$parent_ButtonRow" parentKey="ButtonRow">
                        <Size x="0" y="32"/>
                        <Anchors>
                            <Anchor point="BOTTOMLEFT" x="24" y="24"/>
                            <Anchor point="BOTTOMRIGHT" x="-24" y="24"/>
                        </Anchors>
                        <Frames>
                            <Button name="$parent_PrimaryBtn" parentKey="PrimaryBtn"
                                inherits="FWoWButtonTemplate">
                                <Size x="120" y="32"/>
                                <Anchors>
                                    <Anchor point="RIGHT" x="0" y="0"/>
                                </Anchors>
                            </Button>
                            <!-- Secondary: 8px gap from primary -->
                            <Button name="$parent_SecondaryBtn" parentKey="SecondaryBtn"
                                inherits="FWoWButtonSubtleTemplate">
                                <Size x="120" y="32"/>
                                <Anchors>
                                    <Anchor point="RIGHT" relativeTo="$parent_PrimaryBtn"
                                        relativePoint="LEFT" x="-8" y="0"/>
                                </Anchors>
                            </Button>
                        </Frames>
                    </Frame>
                    <!-- Close X button -->
                    <Button name="$parent_CloseBtn" parentKey="CloseBtn">
                        <Size x="20" y="20"/>
                        <Anchors>
                            <Anchor point="TOPRIGHT" x="-12" y="-12"/>
                        </Anchors>
                        <Layers>
                            <Layer level="ARTWORK">
                                <FontString name="$parent_X" parentKey="X"
                                    inherits="GameFontNormal" justifyH="CENTER" text="×">
                                    <Anchors>
                                        <Anchor point="CENTER"/>
                                    </Anchors>
                                </FontString>
                            </Layer>
                        </Layers>
                        <Scripts>
                            <OnClick function="FWoWContentDialog_OnCloseClick"/>
                        </Scripts>
                    </Button>
                </Frames>
            </Frame>
        </Frames>
        <Scripts>
            <OnLoad function="FWoWContentDialog_OnLoad"/>
            <OnMouseDown function="FWoWContentDialog_OnOverlayClick"/>
        </Scripts>
    </Frame>

</Ui>
