<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <!-- ================================================================
         FWoWCheckBoxTemplate — CheckBox with box + checkmark + label
         Size: 200×20  |  Parts: Box, Check, Label
         ================================================================ -->
    <Button name="FWoWCheckBoxTemplate" virtual="true">
        <Size x="200" y="20"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parent_Box" parentKey="Box">
                    <Size x="20" y="20"/>
                    <Anchors>
                        <Anchor point="LEFT" x="0" y="0"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="$parent_Check" parentKey="Check" hidden="true"
                    justifyH="CENTER" justifyV="MIDDLE">
                    <Anchors>
                        <Anchor point="CENTER" relativeTo="$parent_Box"/>
                    </Anchors>
                </FontString>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="$parent_Label" parentKey="Label"
                    inherits="GameFontNormal" justifyH="LEFT">
                    <Anchors>
                        <Anchor point="LEFT" relativeTo="$parent_Box" relativePoint="RIGHT" x="8" y="0"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Scripts>
            <OnLoad function="FWoWCheckBox_OnLoad"/>
            <OnClick function="FWoWCheckBox_OnClick"/>
            <OnEnter function="FWoWCheckBox_OnEnter"/>
            <OnLeave function="FWoWCheckBox_OnLeave"/>
        </Scripts>
    </Button>

</Ui>
