<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <!-- ================================================================
         FWoWSettingsCardTemplate — Settings card with icon, title,
         description, and action control slot.
         Size: 400×52  |  Parts: BG, Border, Icon, TitleLabel,
               DescLabel, Action (anchor region)
         Pixel-fidelity: DesignSpecs §2.1 + settings.instructions.md
         ================================================================ -->
    <Frame name="FWoWSettingsCardTemplate" virtual="true" enableMouse="true">
        <Size x="400" y="52"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="BG" setAllPoints="true"/>
            </Layer>
            <Layer level="BORDER">
                <Texture parentKey="Border" setAllPoints="true"/>
            </Layer>
            <Layer level="ARTWORK">
                <!-- Leading icon (20×20) -->
                <Texture parentKey="Icon" hidden="true">
                    <Size x="20" y="20"/>
                    <Anchors>
                        <Anchor point="TOPLEFT" x="16" y="-12"/>
                    </Anchors>
                </Texture>
                <!-- Title -->
                <FontString parentKey="TitleLabel" inherits="GameFontNormal" justifyH="LEFT">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.Icon" relativePoint="TOPRIGHT" x="12" y="0"/>
                        <Anchor point="RIGHT" relativeKey="$parent.Action" relativePoint="LEFT" x="-16" y="0"/>
                    </Anchors>
                </FontString>
                <!-- Description (below title) -->
                <FontString parentKey="DescLabel" inherits="GameFontNormal" justifyH="LEFT" hidden="true">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.TitleLabel" relativePoint="BOTTOMLEFT" x="0" y="-12"/>
                        <Anchor point="RIGHT" relativeKey="$parent.TitleLabel" relativePoint="RIGHT"/>
                    </Anchors>
                </FontString>
            </Layer>
            <Layer level="OVERLAY">
                <!-- Hover overlay -->
                <Texture parentKey="Hover" setAllPoints="true" hidden="true"/>
            </Layer>
        </Layers>

        <!-- Action control region (right side) -->
        <Frame name="$parent_Action" parentKey="Action">
            <Size x="160" y="32"/>
            <Anchors>
                <Anchor point="RIGHT" x="-16" y="0"/>
            </Anchors>
        </Frame>

        <Scripts>
            <OnLoad function="FWoWSettingsCard_OnLoad"/>
            <OnEnter function="FWoWSettingsCard_OnEnter"/>
            <OnLeave function="FWoWSettingsCard_OnLeave"/>
            <OnMouseDown function="FWoWSettingsCard_OnMouseDown"/>
            <OnMouseUp function="FWoWSettingsCard_OnMouseUp"/>
        </Scripts>
    </Frame>

</Ui>
