<!-- WinUILib – Settings/SettingsExpander.xml
     Design reference: CommunityToolkit SettingsExpander
     https://learn.microsoft.com/windows/communitytoolkit/controls/settingsexpander
     A SettingsCard that can be expanded to reveal nested setting cards.
-->
<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <Frame name="WUILSettingsExpanderTemplate" virtual="true"
           inherits="WUILSettingsCardTemplate">
        <Layers>
            <Layer level="OVERLAY">
                <!-- Expand/collapse chevron (right edge of card) -->
                <Texture name="$parent_ExpandChevron">
                    <Size x="10" y="10"/>
                    <Anchors><Anchor point="RIGHT" x="-12" y="0"/></Anchors>
                    <Color r="0.68" g="0.68" b="0.72" a="1"/>
                </Texture>
            </Layer>
        </Layers>

        <!-- Children container (clipped) -->
        <Frame name="$parent_ChildrenClip" clipChildren="true">
            <Anchors>
                <Anchor point="TOPLEFT"  x="16" y="-64"/>
                <Anchor point="TOPRIGHT" x="-8" y="-64"/>
            </Anchors>
            <Size x="1" y="0"/>
            <Frame name="$parent_Children">
                <Anchors>
                    <Anchor point="TOPLEFT"/>
                    <Anchor point="TOPRIGHT"/>
                </Anchors>
                <Size x="1" y="1"/>
            </Frame>
        </Frame>

        <Scripts>
            <OnLoad function="WUILSettingsExpander_OnLoad"/>
        </Scripts>
    </Frame>

</Ui>
