<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <!-- ================================================================
         WUILSettingsExpanderTemplate — Expandable card group.
         Header card with chevron; expandable child card container.
         Size: 400×48 (collapsed)
         Parts: Header (BG, TitleLabel, DescLabel, Icon, Chevron, Hover),
                Content (hidden, ContentBG), Cards arranged inside Content.
         ================================================================ -->
    <Frame name="WUILSettingsExpanderTemplate" virtual="true">
        <Size x="400" y="48"/>

        <!-- Header (clickable) -->
        <Button name="$parent_Header" parentKey="Header" enableMouse="true">
            <Anchors>
                <Anchor point="TOPLEFT"/>
                <Anchor point="TOPRIGHT"/>
            </Anchors>
            <Size y="48"/>
            <Layers>
                <Layer level="BACKGROUND">
                    <Texture parentKey="BG" setAllPoints="true"/>
                </Layer>
                <Layer level="BORDER">
                    <Texture parentKey="Border" setAllPoints="true"/>
                </Layer>
                <Layer level="ARTWORK">
                    <Texture parentKey="Icon" hidden="true">
                        <Size x="20" y="20"/>
                        <Anchors>
                            <Anchor point="LEFT" x="16" y="0"/>
                        </Anchors>
                    </Texture>
                    <FontString parentKey="TitleLabel" inherits="GameFontNormal" justifyH="LEFT">
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeKey="$parent.Icon" relativePoint="TOPRIGHT" x="12" y="-4"/>
                            <Anchor point="RIGHT" x="-48" y="0"/>
                        </Anchors>
                    </FontString>
                    <FontString parentKey="DescLabel" inherits="GameFontNormal" justifyH="LEFT" hidden="true">
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeKey="$parent.TitleLabel" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
                            <Anchor point="RIGHT" relativeKey="$parent.TitleLabel" relativePoint="RIGHT"/>
                        </Anchors>
                    </FontString>
                    <!-- Chevron (▸ / ▾) -->
                    <FontString parentKey="Chevron" inherits="GameFontNormal">
                        <Anchors>
                            <Anchor point="RIGHT" x="-16" y="0"/>
                        </Anchors>
                    </FontString>
                </Layer>
                <Layer level="OVERLAY">
                    <Texture parentKey="Hover" setAllPoints="true" hidden="true"/>
                </Layer>
            </Layers>
            <Scripts>
                <OnClick function="WUILSettingsExpander_Header_OnClick"/>
                <OnEnter function="WUILSettingsExpander_Header_OnEnter"/>
                <OnLeave function="WUILSettingsExpander_Header_OnLeave"/>
            </Scripts>
        </Button>

        <!-- Content container (hidden when collapsed) -->
        <Frame name="$parent_Content" parentKey="Content" hidden="true">
            <Anchors>
                <Anchor point="TOPLEFT" relativeKey="$parent.Header" relativePoint="BOTTOMLEFT"/>
                <Anchor point="RIGHT"/>
            </Anchors>
            <Size y="1"/>
            <Layers>
                <Layer level="BACKGROUND">
                    <Texture parentKey="ContentBG" setAllPoints="true"/>
                </Layer>
                <Layer level="BORDER">
                    <Texture parentKey="Separator">
                        <Size y="1"/>
                        <Anchors>
                            <Anchor point="TOPLEFT" x="16"/>
                            <Anchor point="TOPRIGHT" x="-16"/>
                        </Anchors>
                    </Texture>
                </Layer>
            </Layers>
        </Frame>

        <Scripts>
            <OnLoad function="WUILSettingsExpander_OnLoad"/>
        </Scripts>
    </Frame>

</Ui>
