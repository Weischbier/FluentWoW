<!-- WinUILib – Settings/SettingsCard.xml
     Design reference: WinUI SettingsCard (CommunityToolkit.WinUI.UI.Controls)
     https://learn.microsoft.com/windows/communitytoolkit/controls/settingscard
     A card that holds a single setting: icon, title, description, and a
     control on the trailing edge (e.g. ToggleSwitch, ComboBox, CheckBox).
-->
<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <Frame name="WUILSettingsCardTemplate" virtual="true" enableMouse="true">
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parent_BG" setAllPoints="true">
                    <Color r="0.13" g="0.13" b="0.14" a="1"/>
                </Texture>
                <!-- Left accent/icon area -->
                <Texture name="$parent_IconBG">
                    <Size x="48" y="1"/>
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="BOTTOMLEFT"/>
                    </Anchors>
                    <Color r="0.10" g="0.10" b="0.11" a="1"/>
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <!-- Setting icon (optional) -->
                <Texture name="$parent_Icon">
                    <Size x="20" y="20"/>
                    <Anchors><Anchor point="LEFT" x="14" y="0"/></Anchors>
                    <Color r="0.05" g="0.55" b="0.88" a="1"/>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <!-- Hover tint -->
                <Texture name="$parent_Hover" setAllPoints="true">
                    <Color r="1" g="1" b="1" a="0"/>
                </Texture>
            </Layer>
        </Layers>

        <!-- Title -->
        <FontString name="$parent_Title" inherits="GameFontNormal"
                    justifyH="LEFT" justifyV="TOP">
            <Anchors>
                <Anchor point="TOPLEFT"  x="60" y="-10"/>
                <Anchor point="TOPRIGHT" x="-160" y="-10"/>
            </Anchors>
            <Color r="0.95" g="0.95" b="0.97"/>
        </FontString>

        <!-- Description -->
        <FontString name="$parent_Description" inherits="GameFontNormalSmall"
                    justifyH="LEFT" justifyV="TOP" nonspacewrap="true">
            <Anchors>
                <Anchor point="TOPLEFT"  x="60" y="-28"/>
                <Anchor point="TOPRIGHT" x="-160" y="-28"/>
            </Anchors>
            <Color r="0.68" g="0.68" b="0.72"/>
        </FontString>

        <!-- Control slot (right side) – child placed by Lua -->
        <Frame name="$parent_ControlSlot">
            <Size x="150" y="1"/>
            <Anchors>
                <Anchor point="TOPRIGHT"    x="-8" y="-8"/>
                <Anchor point="BOTTOMRIGHT" x="-8" y="8"/>
            </Anchors>
        </Frame>

        <Size x="480" y="64"/>

        <Scripts>
            <OnLoad  function="WUILSettingsCard_OnLoad"/>
            <OnEnter function="WUILSettingsCard_OnEnter"/>
            <OnLeave function="WUILSettingsCard_OnLeave"/>
        </Scripts>
    </Frame>

</Ui>
