<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <!-- ================================================================
         WUILToggleSwitchTemplate — Toggle switch with track + thumb + labels
         Size: 44×20 (switch only) + label area
         Parts: Track, Thumb, OnLabel, OffLabel, HeaderLabel
         ================================================================ -->
    <Frame name="WUILToggleSwitchTemplate" virtual="true" enableMouse="true">
        <Size x="200" y="28"/>
        <Layers>
            <Layer level="ARTWORK">
                <FontString name="$parent_HeaderLabel" parentKey="HeaderLabel"
                    inherits="GameFontNormal" justifyH="LEFT">
                    <Anchors>
                        <Anchor point="LEFT" x="0" y="0"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Frames>
            <Frame name="$parent_Track" parentKey="Track">
                <Size x="40" y="20"/>
                <Anchors>
                    <Anchor point="RIGHT" x="0" y="0"/>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture name="$parent_BG" parentKey="BG" setAllPoints="true"/>
                    </Layer>
                </Layers>
            </Frame>
            <Frame name="$parent_Thumb" parentKey="Thumb">
                <Size x="14" y="14"/>
                <Anchors>
                    <Anchor point="LEFT" relativeTo="$parent_Track" x="3" y="0"/>
                </Anchors>
                <Layers>
                    <Layer level="OVERLAY">
                        <Texture name="$parent_Dot" parentKey="Dot" setAllPoints="true"/>
                    </Layer>
                </Layers>
            </Frame>
        </Frames>
        <Scripts>
            <OnLoad function="WUILToggleSwitch_OnLoad"/>
            <OnMouseUp function="WUILToggleSwitch_OnClick"/>
            <OnEnter function="WUILToggleSwitch_OnEnter"/>
            <OnLeave function="WUILToggleSwitch_OnLeave"/>
        </Scripts>
    </Frame>

</Ui>
