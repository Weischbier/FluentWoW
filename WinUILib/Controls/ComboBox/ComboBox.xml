<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <!-- ================================================================
         WUILComboBoxTemplate — Dropdown selector
         Size: 200×32  |  Parts: BG, Border, SelectedLabel, Arrow,
               Dropdown (hidden), Dropdown.ScrollChild
         ================================================================ -->
    <Frame name="WUILComboBoxTemplate" virtual="true" enableMouse="true">
        <Size x="200" y="32"/>
        <Layers>
            <Layer level="ARTWORK">
                <FontString name="$parent_HeaderLabel" parentKey="HeaderLabel"
                    inherits="GameFontNormalSmall" justifyH="LEFT" hidden="true">
                    <Anchors>
                        <Anchor point="TOPLEFT" x="0" y="0"/>
                        <Anchor point="TOPRIGHT" x="0" y="0"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Frames>
            <Frame name="$parent_Field" parentKey="Field">
                <Anchors>
                    <Anchor point="TOPLEFT"/>
                    <Anchor point="BOTTOMRIGHT"/>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture name="$parent_Shadow" parentKey="Shadow">
                            <Anchors>
                                <Anchor point="TOPLEFT" y="-1"/>
                                <Anchor point="BOTTOMRIGHT" y="1"/>
                            </Anchors>
                        </Texture>
                        <Texture name="$parent_BG" parentKey="BG" setAllPoints="true"/>
                    </Layer>
                    <Layer level="BORDER">
                        <Texture name="$parent_Border" parentKey="Border" setAllPoints="true"/>
                        <Texture name="$parent_TopEdge" parentKey="TopEdge">
                            <Size x="0" y="1"/>
                            <Anchors>
                                <Anchor point="TOPLEFT"/>
                                <Anchor point="TOPRIGHT"/>
                            </Anchors>
                        </Texture>
                    </Layer>
                    <Layer level="BORDER" textureSubLevel="1">
                        <Texture name="$parent_BottomEdge" parentKey="BottomEdge">
                            <Size x="0" y="2"/>
                            <Anchors>
                                <Anchor point="BOTTOMLEFT"/>
                                <Anchor point="BOTTOMRIGHT"/>
                            </Anchors>
                        </Texture>
                    </Layer>
                    <Layer level="ARTWORK">
                        <FontString name="$parent_SelectedLabel" parentKey="SelectedLabel"
                            inherits="GameFontHighlight" justifyH="LEFT">
                            <Anchors>
                                <Anchor point="LEFT" x="12" y="0"/>
                                <Anchor point="RIGHT" x="-28" y="0"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                    <Layer level="ARTWORK">
                        <FontString name="$parent_Arrow" parentKey="Arrow"
                            inherits="GameFontNormal" justifyH="CENTER" text="▾">
                            <Anchors>
                                <Anchor point="RIGHT" x="-8" y="0"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
            </Frame>
            <Frame name="$parent_Dropdown" parentKey="Dropdown" hidden="true"
                frameStrata="DIALOG">
                <Size x="200" y="100"/>
                <Anchors>
                    <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture name="$parent_DropBG" parentKey="DropBG" setAllPoints="true"/>
                    </Layer>
                    <Layer level="BORDER">
                        <Texture name="$parent_DropBorder" parentKey="DropBorder" setAllPoints="true"/>
                    </Layer>
                </Layers>
                <Frames>
                    <ScrollFrame name="$parent_Scroll" parentKey="Scroll">
                        <Anchors>
                            <Anchor point="TOPLEFT" x="4" y="-4"/>
                            <Anchor point="BOTTOMRIGHT" x="-4" y="4"/>
                        </Anchors>
                        <Frames>
                            <Frame name="$parent_Child" parentKey="Child">
                                <Size x="192" y="1"/>
                            </Frame>
                        </Frames>
                    </ScrollFrame>
                </Frames>
            </Frame>
        </Frames>
        <Scripts>
            <OnLoad function="WUILComboBox_OnLoad"/>
            <OnMouseUp function="WUILComboBox_OnClick"/>
            <OnEnter function="WUILComboBox_OnEnter"/>
            <OnLeave function="WUILComboBox_OnLeave"/>
            <OnHide function="WUILComboBox_OnHide"/>
        </Scripts>
    </Frame>

    <!-- Item template (used by FramePool) -->
    <Button name="WUILComboBoxItemTemplate" virtual="true">
        <Size x="192" y="28"/>
        <Layers>
            <Layer level="HIGHLIGHT">
                <Texture name="$parent_Highlight" parentKey="Highlight" setAllPoints="true" alphaMode="ADD"/>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="$parent_Text" parentKey="Text"
                    inherits="GameFontHighlight" justifyH="LEFT">
                    <Anchors>
                        <Anchor point="LEFT" x="8" y="0"/>
                        <Anchor point="RIGHT" x="-8" y="0"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Scripts>
            <OnClick function="WUILComboBoxItem_OnClick"/>
            <OnEnter function="WUILComboBoxItem_OnEnter"/>
            <OnLeave function="WUILComboBoxItem_OnLeave"/>
        </Scripts>
    </Button>

</Ui>
