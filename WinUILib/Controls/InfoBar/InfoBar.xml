<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <!-- ================================================================
         WUILInfoBarTemplate — Informational notification bar
         Size: 400×48  |  Parts: BG, LeftEdge, Icon, Title, Message, CloseBtn
         ================================================================ -->
    <Frame name="WUILInfoBarTemplate" virtual="true" enableMouse="true">
        <Size x="400" y="48"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parent_BG" parentKey="BG" setAllPoints="true"/>
            </Layer>
            <Layer level="BORDER">
                <Texture name="$parent_LeftEdge" parentKey="LeftEdge">
                    <Size x="3" y="0"/>
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="BOTTOMLEFT"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <Texture name="$parent_Icon" parentKey="Icon">
                    <Size x="16" y="16"/>
                    <Anchors>
                        <Anchor point="LEFT" x="16" y="0"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="$parent_Title" parentKey="Title"
                    inherits="GameFontNormal" justifyH="LEFT">
                    <Anchors>
                        <Anchor point="LEFT" relativeTo="$parent_Icon" relativePoint="RIGHT" x="12" y="0"/>
                    </Anchors>
                </FontString>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="$parent_Message" parentKey="Message"
                    inherits="GameFontHighlight" justifyH="LEFT">
                    <Anchors>
                        <Anchor point="LEFT" relativeTo="$parent_Title" relativePoint="RIGHT" x="8" y="0"/>
                        <Anchor point="RIGHT" x="-40" y="0"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Frames>
            <Button name="$parent_CloseBtn" parentKey="CloseBtn">
                <Size x="20" y="20"/>
                <Anchors>
                    <Anchor point="RIGHT" x="-12" y="0"/>
                </Anchors>
                <Layers>
                    <Layer level="ARTWORK">
                        <FontString name="$parent_X" parentKey="X"
                            inherits="GameFontNormal" justifyH="CENTER" text="×">
                            <Anchors>
                                <Anchor point="CENTER"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Scripts>
                    <OnClick function="WUILInfoBar_OnClose"/>
                </Scripts>
            </Button>
        </Frames>
        <Scripts>
            <OnLoad function="WUILInfoBar_OnLoad"/>
        </Scripts>
    </Frame>

</Ui>
