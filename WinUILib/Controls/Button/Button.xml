<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <!-- ================================================================
         WUILButtonTemplate — Standard accent (primary) button
         Size: 120×32  |  Parts: BG, TopEdge, Label, Overlay
         ================================================================ -->
    <Button name="WUILButtonTemplate" virtual="true">
        <Size x="120" y="32"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parent_Shadow" parentKey="Shadow">
                    <Anchors>
                        <Anchor point="TOPLEFT" y="-1"/>
                        <Anchor point="BOTTOMRIGHT" y="1"/>
                    </Anchors>
                </Texture>
                <Texture name="$parent_BG" parentKey="BG" setAllPoints="true"/>
            </Layer>
            <Layer level="BORDER">
                <Texture name="$parent_TopEdge" parentKey="TopEdge">
                    <Size x="0" y="1"/>
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="TOPRIGHT"/>
                    </Anchors>
                </Texture>
                <Texture name="$parent_BottomEdge" parentKey="BottomEdge">
                    <Size x="0" y="1"/>
                    <Anchors>
                        <Anchor point="BOTTOMLEFT"/>
                        <Anchor point="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="$parent_Label" parentKey="Label"
                    inherits="GameFontNormal" justifyH="CENTER">
                    <Anchors>
                        <Anchor point="CENTER"/>
                    </Anchors>
                </FontString>
            </Layer>
            <Layer level="HIGHLIGHT">
                <Texture name="$parent_Overlay" parentKey="Overlay" setAllPoints="true" alphaMode="ADD"/>
            </Layer>
        </Layers>
        <Scripts>
            <OnLoad function="WUILButton_OnLoad"/>
            <OnEnter function="WUILButton_OnEnter"/>
            <OnLeave function="WUILButton_OnLeave"/>
            <OnMouseDown function="WUILButton_OnMouseDown"/>
            <OnMouseUp function="WUILButton_OnMouseUp"/>
            <OnClick function="WUILButton_OnClick"/>
            <OnEnable function="WUILButton_OnEnable"/>
            <OnDisable function="WUILButton_OnDisable"/>
        </Scripts>
    </Button>

    <!-- ================================================================
         WUILButtonSubtleTemplate — Subtle (secondary) button
         ================================================================ -->
    <Button name="WUILButtonSubtleTemplate" virtual="true" inherits="WUILButtonTemplate">
        <Scripts>
            <OnLoad function="WUILButtonSubtle_OnLoad"/>
        </Scripts>
    </Button>

    <!-- ================================================================
         WUILButtonDestructiveTemplate — Destructive (danger) button
         ================================================================ -->
    <Button name="WUILButtonDestructiveTemplate" virtual="true" inherits="WUILButtonTemplate">
        <Scripts>
            <OnLoad function="WUILButtonDestructive_OnLoad"/>
        </Scripts>
    </Button>

    <!-- ================================================================
         WUILIconButtonTemplate — Icon-only button (32×32)
         Parts: BG, Icon, Overlay
         ================================================================ -->
    <Button name="WUILIconButtonTemplate" virtual="true">
        <Size x="32" y="32"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parent_Shadow" parentKey="Shadow">
                    <Anchors>
                        <Anchor point="TOPLEFT" y="-1"/>
                        <Anchor point="BOTTOMRIGHT" y="1"/>
                    </Anchors>
                </Texture>
                <Texture name="$parent_BG" parentKey="BG" setAllPoints="true"/>
            </Layer>
            <Layer level="BORDER">
                <Texture name="$parent_Border" parentKey="Border" setAllPoints="true"/>
            </Layer>
            <Layer level="ARTWORK">
                <Texture name="$parent_Icon" parentKey="Icon">
                    <Size x="16" y="16"/>
                    <Anchors>
                        <Anchor point="CENTER"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="HIGHLIGHT">
                <Texture name="$parent_Overlay" parentKey="Overlay" setAllPoints="true" alphaMode="ADD"/>
            </Layer>
        </Layers>
        <Scripts>
            <OnLoad function="WUILIconButton_OnLoad"/>
            <OnEnter function="WUILButton_OnEnter"/>
            <OnLeave function="WUILButton_OnLeave"/>
            <OnMouseDown function="WUILButton_OnMouseDown"/>
            <OnMouseUp function="WUILButton_OnMouseUp"/>
            <OnClick function="WUILButton_OnClick"/>
            <OnEnable function="WUILButton_OnEnable"/>
            <OnDisable function="WUILButton_OnDisable"/>
        </Scripts>
    </Button>

    <!-- ================================================================
         WUILToggleButtonTemplate — Toggle button with checked state
         Parts: BG, Label, Indicator, Overlay
         ================================================================ -->
    <Button name="WUILToggleButtonTemplate" virtual="true">
        <Size x="120" y="32"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parent_Shadow" parentKey="Shadow">
                    <Anchors>
                        <Anchor point="TOPLEFT" y="-1"/>
                        <Anchor point="BOTTOMRIGHT" y="1"/>
                    </Anchors>
                </Texture>
                <Texture name="$parent_BG" parentKey="BG" setAllPoints="true"/>
            </Layer>
            <Layer level="BORDER">
                <Texture name="$parent_TopEdge" parentKey="TopEdge">
                    <Size x="0" y="1"/>
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="TOPRIGHT"/>
                    </Anchors>
                </Texture>
                <Texture name="$parent_BottomEdge" parentKey="BottomEdge">
                    <Size x="0" y="1"/>
                    <Anchors>
                        <Anchor point="BOTTOMLEFT"/>
                        <Anchor point="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="$parent_Label" parentKey="Label"
                    inherits="GameFontNormal" justifyH="CENTER">
                    <Anchors>
                        <Anchor point="CENTER"/>
                    </Anchors>
                </FontString>
            </Layer>
            <Layer level="HIGHLIGHT">
                <Texture name="$parent_Overlay" parentKey="Overlay" setAllPoints="true" alphaMode="ADD"/>
            </Layer>
        </Layers>
        <Scripts>
            <OnLoad function="WUILToggleButton_OnLoad"/>
            <OnEnter function="WUILButton_OnEnter"/>
            <OnLeave function="WUILButton_OnLeave"/>
            <OnMouseDown function="WUILButton_OnMouseDown"/>
            <OnMouseUp function="WUILButton_OnMouseUp"/>
            <OnClick function="WUILToggleButton_OnClick"/>
            <OnEnable function="WUILButton_OnEnable"/>
            <OnDisable function="WUILButton_OnDisable"/>
        </Scripts>
    </Button>

</Ui>
