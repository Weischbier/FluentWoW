<!-- WinUILib – Controls/Expander/Expander.xml
     Design reference: WinUI Expander
     https://learn.microsoft.com/windows/apps/design/controls/expander
     Collapsible section with a header and animated body reveal.
-->
<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <Frame name="WUILExpanderTemplate" virtual="true">
        <!-- Header button -->
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parent_HeaderBG">
                    <Size x="1" y="40"/>
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="TOPRIGHT"/>
                    </Anchors>
                    <Color r="0.17" g="0.17" b="0.19" a="1"/>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <!-- Chevron indicator -->
                <Texture name="$parent_Chevron">
                    <Size x="10" y="10"/>
                    <Anchors><Anchor point="RIGHT" x="-12" y="0" relativePoint="RIGHT"
                             relativeTo="$parent_HeaderBG"/></Anchors>
                    <Color r="0.68" g="0.68" b="0.72" a="1"/>
                </Texture>
            </Layer>
        </Layers>

        <!-- Header title -->
        <FontString name="$parent_HeaderTitle" inherits="GameFontNormal"
                    justifyH="LEFT" justifyV="MIDDLE">
            <Anchors>
                <Anchor point="LEFT"  x="12" y="-10" relativeTo="$parent" relativePoint="TOPLEFT"/>
                <Anchor point="RIGHT" x="-32" y="-10" relativeTo="$parent" relativePoint="TOPRIGHT"/>
            </Anchors>
            <Color r="0.85" g="0.85" b="0.88"/>
        </FontString>

        <!-- Expandable content clipping frame -->
        <Frame name="$parent_ContentClip" clipChildren="true">
            <Anchors>
                <Anchor point="TOPLEFT"  x="0" y="-40"/>
                <Anchor point="TOPRIGHT" x="0" y="-40"/>
            </Anchors>
            <Size x="1" y="0"/>
            <!-- Inner content frame (placed here by Lua) -->
            <Frame name="$parent_Content">
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture name="$parent_ContentBG" setAllPoints="true">
                            <Color r="0.10" g="0.10" b="0.11" a="1"/>
                        </Texture>
                    </Layer>
                </Layers>
                <Anchors>
                    <Anchor point="TOPLEFT"/>
                    <Anchor point="TOPRIGHT"/>
                </Anchors>
                <Size x="1" y="120"/>
            </Frame>
        </Frame>

        <Size x="300" y="40"/>

        <Scripts>
            <OnLoad function="WUILExpander_OnLoad"/>
        </Scripts>
    </Frame>

</Ui>
