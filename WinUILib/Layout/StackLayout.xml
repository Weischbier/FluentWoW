<Ui xmlns="http://www.blizzard.com/wow/ui/">

    <!-- ================================================================
         WUILStackLayoutTemplate — Vertical / horizontal stack container
         Size: 200×1 (auto-grows)  |  Parts: (children managed in Lua)
         ================================================================ -->
    <Frame name="WUILStackLayoutTemplate" virtual="true">
        <Size x="200" y="1"/>
        <Scripts>
            <OnLoad function="WUILStackLayout_OnLoad"/>
            <OnSizeChanged function="WUILStackLayout_OnSizeChanged"/>
        </Scripts>
    </Frame>

</Ui>
